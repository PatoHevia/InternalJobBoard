<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Internal Job Board" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="#">Internal Job Board</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
        <% if user_signed_in? %>
          <li class="nav-item">
            <a class="nav-link" href="#">Hola, <%= current_user.name %>!</a>
          </li>
          <li class="nav-item">
  <%= form_with url: destroy_user_session_path, method: :delete, class: "d-inline" do %>
    <button type="submit" class="btn btn-link nav-link" data-confirm="¿Estás seguro de que deseas cerrar sesión?">Cerrar Sesión</button>
  <% end %>
</li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Iniciar Sesión", new_user_session_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>       
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="container mt-4">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-light text-center py-3 mt-auto">
      <p>&copy; <%= Time.now.year %> Internal Job Board. Todos los derechos reservados.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
