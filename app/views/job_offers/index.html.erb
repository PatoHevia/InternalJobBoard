<h1>Ofertas de Trabajo</h1>

<%= link_to "Nueva Oferta de Trabajo", new_job_offer_path, class: "btn btn-primary mb-3" %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Título</th>
      <th>Descripción</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @job_offers.each do |job_offer| %>
      <tr>
        <td><%= job_offer.title %></td>
        <td><%= truncate(job_offer.description, length: 100) %></td>
        <td>
          <%= link_to "Ver", job_offer_path(job_offer), class: "btn btn-info btn-sm" %>
          <%= link_to "Editar", edit_job_offer_path(job_offer), class: "btn btn-warning btn-sm" %>
          <%= link_to "Eliminar", job_offer_path(job_offer), method: :delete, data: { confirm: "¿Estás seguro de que deseas eliminar esta oferta?" }, class: "btn btn-danger btn-sm" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
